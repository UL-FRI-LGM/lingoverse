  - NodeGUID: f3547453-415c-48b7-b7f8-14280d8314ad
    DialogueText: Guten Abend, mein Name ist Dieter.
    Position: {x: 205, y: 200}
    AudioClip: {fileID: 8300000, guid: a15205fd7f972a146b14bb6562e5eed9, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: a8974110-9ccb-4db5-9d91-171706f415fa
    DialogueText: Und wie ist dein Name?
    Position: {x: 567, y: 200}
    AudioClip: {fileID: 8300000, guid: c6237f2711f531a45b92d671c7731a91, type: 3}
    allCorrect: 0
    dialogueType: 1
  - NodeGUID: 749969d5-748c-4558-bbd6-3452b8fc0ab3
    DialogueText: "Sch\xF6n, dich zu treffen, [Name]."
    Position: {x: 942, y: 155}
    AudioClip: {fileID: 8300000, guid: 0c2ed36d243aca444a47555887f263cb, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: ccaad560-a737-4bac-8c6f-306e4bf35186
    DialogueText: Ich arbeite als Koch.
    Position: {x: 1347, y: 248}
    AudioClip: {fileID: 8300000, guid: 72403fd4bb49b8d46be383f023973a87, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 961bdfc5-aca6-404f-929e-412e2a8aa8da
    DialogueText: (Das ist richtig)
    Position: {x: 1926, y: 184}
    AudioClip: {fileID: 0}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 8654f151-22ed-4c21-9fbc-0a4135043aa6
    DialogueText: "Mein Hund hei\xDFt Max."
    Position: {x: 2197, y: 297}
    AudioClip: {fileID: 8300000, guid: 53e4a0d6bf895ef4d9deccd4fe8c62c5, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 86378c79-6e9d-4069-bb62-d82c65fd70a2
    DialogueText: Das ist nicht die Frage, die ich erwartet habe. (You chose the
      wrong answer, try again)
    Position: {x: 2851, y: 442}
    AudioClip: {fileID: 8300000, guid: f74a1435d1a728540a01327fee6046c4, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: e7752cac-2966-427f-b674-7a9b9576d510
    DialogueText: Im Sommer gehe ich oft schwimmen.
    Position: {x: 3507, y: 339}
    AudioClip: {fileID: 8300000, guid: 537903c8ba1a4ce41b2889e108526622, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 9f5073c8-fd67-44e9-8fa9-8319e53fdc78
    DialogueText: Das passt nicht zu meiner Aussage. (You chose the wrong answer,
      try again)
    Position: {x: 4196, y: 451}
    AudioClip: {fileID: 8300000, guid: f74a1435d1a728540a01327fee6046c4, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 680b9bab-dadb-4012-9beb-f8f0da2fbc5b
    DialogueText: Ich schwimme am liebsten im See.
    Position: {x: 4298, y: 273}
    AudioClip: {fileID: 8300000, guid: 10801f04fc3547e4686c1ff75031db37, type: 3}
