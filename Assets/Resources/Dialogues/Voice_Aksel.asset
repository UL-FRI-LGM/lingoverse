  - NodeGUID: 24c38037-e86e-48a7-847e-6d3c29737499
    DialogueText: Hallo, ich habe Hunger, aber wir haben keine Lebensmittel.
    Position: {x: 191, y: 163}
    AudioClip: {fileID: 8300000, guid: 1c45d34949113bb4faf08bd2c423fdc9, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 46efb3ae-e163-447a-9cd6-2c11308d5d36
    DialogueText: Wir haben nur Salz und Pfeffer.
