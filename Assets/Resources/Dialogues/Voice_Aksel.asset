    AudioClip: {fileID: 8300000, guid: b70212a5ad5c1e34282a014e70457940, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: c1477946-18ca-4a5e-a8ee-aa969afa7055
    DialogueText: 'Nein, ich trinke kein Bier. Ich werde etwas ___ kaufen. '
