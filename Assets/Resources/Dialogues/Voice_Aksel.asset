    AudioClip: {fileID: 8300000, guid: 36935d7c3fe66c74dba6b18490f67443, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 98a18d1f-358a-499e-b89e-938f6c74416d
    DialogueText: 'Ich werde vielleicht etwas trinken. '
