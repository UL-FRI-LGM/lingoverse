    AudioClip: {fileID: 8300000, guid: f08a90938d761cc4ebc8fdd5619255d4, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: 9b8e081e-f4a1-4664-9db3-76855f9042f3
    DialogueText: 'Ich ___ eine Pizza. '
    Position: {x: 1751, y: 196}
    AudioClip: {fileID: 8300000, guid: ed4ae2ce5b293214089b78b012354685, type: 3}
    allCorrect: 0
    dialogueType: 0
  - NodeGUID: a4b64a83-b090-44bc-8d2f-7ed156a981db
    DialogueText: "F\xFCr meine Pizza muss ich Mehl, Tomatenso\xDFe, Wurst und was
      noch kaufen? "
